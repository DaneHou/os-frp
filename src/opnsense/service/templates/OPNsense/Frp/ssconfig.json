{% if helpers.exists('OPNsense.frp.shadowsocks.enabled') and OPNsense.frp.shadowsocks.enabled == '1' %}
{
    "server": "{{ OPNsense.frp.shadowsocks.serverAddr }}",
    "server_port": {{ OPNsense.frp.shadowsocks.serverPort }},
    "password": "{{ OPNsense.frp.shadowsocks.password }}",
    "timeout": {{ OPNsense.frp.shadowsocks.timeout }},
    "method": "{{ OPNsense.frp.shadowsocks.cipher }}",
    "mode": "{{ OPNsense.frp.shadowsocks.tcpudpmode }}"
}
{% endif %}
