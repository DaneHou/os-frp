# FRP Docker Environment
FRP_VERSION=0.67.0
HYSTERIA2_VERSION=2.5.1
SHADOW_TLS_VERSION=0.2.25

# Mode: client or server
FRP_MODE=client

# Features
FRP_WATCHDOG_ENABLED=true
HYSTERIA2_ENABLED=false
SHADOW_TLS_ENABLED=false

# Health check URL (optional, for Docker HEALTHCHECK)
FRP_HEALTH_CHECK_URL=

# FRP Admin API (for watchdog health checks)
FRP_ADMIN_ADDR=127.0.0.1
FRP_ADMIN_PORT=7400
FRP_ADMIN_USER=
FRP_ADMIN_PWD=
