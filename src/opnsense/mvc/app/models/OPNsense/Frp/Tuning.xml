<model>
    <mount>//OPNsense/frp/tuning</mount>
    <description>FRP Tuning Settings</description>
    <version>1.0.0</version>
    <items>
        <bbrEnabled type="BooleanField">
            <default>0</default>
        </bbrEnabled>
        <mtuClampEnabled type="BooleanField">
            <default>0</default>
        </mtuClampEnabled>
        <mtuValue type="IntegerField">
            <default>1300</default>
            <MinimumValue>576</MinimumValue>
            <MaximumValue>1500</MaximumValue>
        </mtuValue>
        <mtuInterface type="TextField">
            <default>wan</default>
        </mtuInterface>
        <mssClampEnabled type="BooleanField">
            <default>0</default>
        </mssClampEnabled>
        <mssValue type="IntegerField">
            <default>1260</default>
            <MinimumValue>536</MinimumValue>
            <MaximumValue>1460</MaximumValue>
        </mssValue>
        <mssInterface type="TextField">
            <default>wan</default>
        </mssInterface>
    </items>
</model>
