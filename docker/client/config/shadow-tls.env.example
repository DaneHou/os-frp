# Shadow-TLS Client Configuration
# Disguises FRP traffic as normal HTTPS to evade GFW DPI

SHADOW_TLS_ENABLED=false
SHADOW_TLS_SERVER=us-server:443
SHADOW_TLS_PASSWORD=your-password
SHADOW_TLS_SNI=www.microsoft.com
SHADOW_TLS_LISTEN=127.0.0.1:1234

# When shadow-TLS is enabled, set frpc.toml serverAddr to 127.0.0.1:1234
# The traffic flow is:
# frpc -> shadow-tls-client:1234 ==internet==> shadow-tls-server:443 -> frps:7000
