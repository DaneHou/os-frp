<model>
    <mount>//OPNsense/frp/client</mount>
    <description>FRP Client Settings</description>
    <version>1.0.0</version>
    <items>
        <enabled type="BooleanField">
            <default>0</default>
            <Required>Y</Required>
        </enabled>
        <serverAddr type="TextField">
            <Required>Y</Required>
        </serverAddr>
        <serverPort type="IntegerField">
            <default>7000</default>
            <Required>Y</Required>
            <MinimumValue>1</MinimumValue>
            <MaximumValue>65535</MaximumValue>
        </serverPort>
        <authMethod type="OptionField">
            <default>token</default>
            <BlankDesc>None</BlankDesc>
            <OptionValues>
                <token>Token</token>
            </OptionValues>
        </authMethod>
        <authToken type="TextField"/>
        <transportProtocol type="OptionField">
            <default>tcp</default>
            <OptionValues>
                <tcp>TCP</tcp>
                <websocket>WebSocket</websocket>
                <wss>WSS (WebSocket over TLS)</wss>
                <kcp>KCP (UDP)</kcp>
                <quic>QUIC (UDP)</quic>
            </OptionValues>
        </transportProtocol>
        <transportTcpMux type="BooleanField">
            <default>1</default>
        </transportTcpMux>
        <transportTcpMuxKeepaliveInterval type="IntegerField">
            <default>10</default>
            <MinimumValue>1</MinimumValue>
            <MaximumValue>600</MaximumValue>
        </transportTcpMuxKeepaliveInterval>
        <transportHeartbeatInterval type="IntegerField">
            <default>10</default>
            <MinimumValue>1</MinimumValue>
            <MaximumValue>600</MaximumValue>
        </transportHeartbeatInterval>
        <transportHeartbeatTimeout type="IntegerField">
            <default>30</default>
            <MinimumValue>5</MinimumValue>
            <MaximumValue>600</MaximumValue>
        </transportHeartbeatTimeout>
        <transportTlsEnable type="BooleanField">
            <default>0</default>
        </transportTlsEnable>
        <transportTlsServerName type="TextField"/>
        <transportPoolCount type="IntegerField">
            <default>5</default>
            <MinimumValue>0</MinimumValue>
            <MaximumValue>100</MaximumValue>
        </transportPoolCount>
        <transportDialServerTimeout type="IntegerField">
            <default>10</default>
            <MinimumValue>1</MinimumValue>
            <MaximumValue>120</MaximumValue>
        </transportDialServerTimeout>
        <transportDialServerKeepalive type="IntegerField">
            <default>7200</default>
            <MinimumValue>-1</MinimumValue>
            <MaximumValue>86400</MaximumValue>
        </transportDialServerKeepalive>
        <transportProxyURL type="TextField"/>
        <transportQuicKeepalivePeriod type="IntegerField">
            <default>10</default>
            <MinimumValue>1</MinimumValue>
            <MaximumValue>600</MaximumValue>
        </transportQuicKeepalivePeriod>
        <transportQuicMaxIdleTimeout type="IntegerField">
            <default>30</default>
            <MinimumValue>5</MinimumValue>
            <MaximumValue>600</MaximumValue>
        </transportQuicMaxIdleTimeout>
        <transportQuicMaxIncomingStreams type="IntegerField">
            <default>100000</default>
            <MinimumValue>1</MinimumValue>
            <MaximumValue>1000000</MaximumValue>
        </transportQuicMaxIncomingStreams>
        <loginFailExit type="BooleanField">
            <default>0</default>
        </loginFailExit>
        <logLevel type="OptionField">
            <default>info</default>
            <OptionValues>
                <trace>Trace</trace>
                <debug>Debug</debug>
                <info>Info</info>
                <warn>Warning</warn>
                <error>Error</error>
            </OptionValues>
        </logLevel>
        <bbrEnabled type="BooleanField">
            <default>0</default>
        </bbrEnabled>
        <mssClampEnabled type="BooleanField">
            <default>0</default>
        </mssClampEnabled>
        <mssValue type="IntegerField">
            <default>1260</default>
            <MinimumValue>536</MinimumValue>
            <MaximumValue>1460</MaximumValue>
        </mssValue>
        <tfoEnabled type="BooleanField">
            <default>0</default>
        </tfoEnabled>
        <tcpTuningEnabled type="BooleanField">
            <default>0</default>
        </tcpTuningEnabled>
        <monitorInterval type="OptionField">
            <default>2</default>
            <OptionValues>
                <option1 value="1">1s</option1>
                <option2 value="2">2s</option2>
                <option5 value="5">5s</option5>
                <option10 value="10">10s</option10>
                <option30 value="30">30s</option30>
            </OptionValues>
        </monitorInterval>
        <webServerEnabled type="BooleanField">
            <default>0</default>
        </webServerEnabled>
        <webServerAddr type="TextField">
            <default>127.0.0.1</default>
        </webServerAddr>
        <webServerPort type="IntegerField">
            <default>7400</default>
            <MinimumValue>1</MinimumValue>
            <MaximumValue>65535</MaximumValue>
        </webServerPort>
        <webServerUser type="TextField"/>
        <webServerPassword type="TextField"/>
        <proxies>
            <proxy type="ArrayField">
                <enabled type="BooleanField">
                    <default>1</default>
                    <Required>Y</Required>
                </enabled>
                <name type="TextField">
                    <Required>Y</Required>
                    <Mask>/^[a-zA-Z0-9_-]+$/</Mask>
                    <MinimumLength>1</MinimumLength>
                    <MaximumLength>32</MaximumLength>
                </name>
                <proxyType type="OptionField">
                    <default>tcp</default>
                    <OptionValues>
                        <tcp>TCP</tcp>
                        <udp>UDP</udp>
                        <http>HTTP</http>
                        <https>HTTPS</https>
                        <stcp>STCP</stcp>
                        <sudp>SUDP</sudp>
                        <xtcp>XTCP</xtcp>
                        <tcpmux>TCPMUX</tcpmux>
                    </OptionValues>
                </proxyType>
                <localIP type="TextField">
                    <default>127.0.0.1</default>
                </localIP>
                <localPort type="IntegerField">
                    <Required>Y</Required>
                    <MinimumValue>1</MinimumValue>
                    <MaximumValue>65535</MaximumValue>
                </localPort>
                <remotePort type="IntegerField">
                    <MinimumValue>0</MinimumValue>
                    <MaximumValue>65535</MaximumValue>
                </remotePort>
                <customDomains type="TextField"/>
                <subdomain type="TextField"/>
                <httpUser type="TextField"/>
                <httpPassword type="TextField"/>
                <bandwidthLimit type="TextField"/>
                <secretKey type="TextField"/>
                <useCompression type="BooleanField">
                    <default>0</default>
                </useCompression>
                <useEncryption type="BooleanField">
                    <default>0</default>
                </useEncryption>
            </proxy>
        </proxies>
        <healthTargets>
            <healthTarget type="ArrayField">
                <enabled type="BooleanField">
                    <default>1</default>
                </enabled>
                <label type="TextField">
                    <Required>Y</Required>
                    <MinimumLength>1</MinimumLength>
                    <MaximumLength>64</MaximumLength>
                </label>
                <url type="TextField">
                    <Required>Y</Required>
                    <Mask>/^https?:\/\/.+/</Mask>
                </url>
            </healthTarget>
        </healthTargets>
    </items>
</model>
