<form>
    <field>
        <type>header</type>
        <label>TCP BBR Congestion Control</label>
    </field>
    <field>
        <id>tuning.bbrEnabled</id>
        <label>Enable BBR</label>
        <type>checkbox</type>
        <help>Enable TCP BBR congestion control (FreeBSD kernel module).</help>
    </field>
    <field>
        <type>header</type>
        <label>MTU Clamping</label>
    </field>
    <field>
        <id>tuning.mtuClampEnabled</id>
        <label>Enable MTU Clamping</label>
        <type>checkbox</type>
        <help>Set interface MTU value.</help>
    </field>
    <field>
        <id>tuning.mtuValue</id>
        <label>MTU Value</label>
        <type>text</type>
        <help>MTU value (576-1500, default: 1300).</help>
    </field>
    <field>
        <id>tuning.mtuInterface</id>
        <label>MTU Interface</label>
        <type>text</type>
        <help>Interface name for MTU clamping (e.g., wan, igb0).</help>
    </field>
    <field>
        <type>header</type>
        <label>MSS Clamping</label>
    </field>
    <field>
        <id>tuning.mssClampEnabled</id>
        <label>Enable MSS Clamping</label>
        <type>checkbox</type>
        <help>Enable TCP MSS clamping via pf scrub rule.</help>
    </field>
    <field>
        <id>tuning.mssValue</id>
        <label>MSS Value</label>
        <type>text</type>
        <help>Maximum Segment Size (536-1460, default: 1260).</help>
    </field>
    <field>
        <id>tuning.mssInterface</id>
        <label>MSS Interface</label>
        <type>text</type>
        <help>Interface name for MSS clamping (e.g., wan, igb0).</help>
    </field>
</form>
