# ============================================================
# FRP 客户端 Docker 配置 / FRP Client Docker Configuration
# ============================================================
# 使用方法 / Usage:
#   1. cp .env.example .env
#   2. cp config/frpc.toml.example config/frpc.toml
#   3. 编辑 .env 和 frpc.toml / Edit .env and frpc.toml
#   4. docker compose up -d
# ============================================================

# --- 基本设置 / Basic settings ---
FRP_MODE=client
FRP_WATCHDOG_ENABLED=true

# --- Shadow-TLS 翻墙 (默认关闭) / Shadow-TLS GFW evasion (off by default) ---
# 将 FRP 流量伪装成访问正常网站的 HTTPS，绕过 GFW 深度包检测
# Disguises FRP traffic as normal HTTPS to evade GFW deep packet inspection
# 启用后需同时修改 frpc.toml 的 serverAddr 和 serverPort 指向 SHADOW_TLS_LISTEN
# When enabled, also set frpc.toml serverAddr/serverPort to match SHADOW_TLS_LISTEN
SHADOW_TLS_ENABLED=false
SHADOW_TLS_LISTEN=127.0.0.1:1234        # 本地监听，frpc 连这里 / Local listen, frpc connects here
SHADOW_TLS_SNI=www.microsoft.com         # 伪装的目标域名 / Disguise target domain
#SHADOW_TLS_SERVER=your-us-server:8443   # 美国端 shadow-tls 地址 / US-side shadow-tls address
#SHADOW_TLS_PASSWORD=your-password       # 两端必须一致 / Must match server side

# --- Hysteria2 UDP 加速 (默认关闭) / Hysteria2 UDP acceleration (off by default) ---
# 基于 QUIC 的高速协议，适合丢包严重的网络环境
# QUIC-based high-speed protocol, ideal for lossy networks
# 启用后需提供 config/hysteria2.yaml / When enabled, provide config/hysteria2.yaml
HYSTERIA2_ENABLED=false

# --- 传输探测 (可选) / Transport probe (optional) ---
# 自动比较 TCP 和 QUIC 延迟，推荐最优协议
# Auto-compares TCP vs QUIC latency, recommends optimal protocol
FRP_SERVER_PORT=7000                     # FRP 服务端口 / FRP server port
#FRP_SERVER_ADDR=                        # 填美国服务器 IP / US server IP (required to enable probe)
#FRP_QUIC_PORT=                          # 留空=不测试 QUIC / Empty=skip QUIC test

# --- 健康检查 / Health check ---
# 需要 frpc.toml 中启用 webServer 才生效
# Requires webServer enabled in frpc.toml
FRP_ADMIN_ADDR=127.0.0.1
FRP_ADMIN_PORT=7400
#FRP_ADMIN_USER=
#FRP_ADMIN_PWD=
#FRP_HEALTH_CHECK_URL=                   # 外部连通性检查 URL / External connectivity check URL
