# ============================================================
# FRP 服务端 Docker 配置 / FRP Server Docker Configuration
# ============================================================
# 使用方法 / Usage:
#   1. cp .env.example .env
#   2. cp config/frps.toml.example config/frps.toml
#   3. 编辑 .env 和 frps.toml / Edit .env and frps.toml
#   4. docker compose up -d
# ============================================================

# --- 基本设置 / Basic settings ---
FRP_MODE=server
FRP_WATCHDOG_ENABLED=true

# --- Shadow-TLS (默认关闭) / Shadow-TLS (off by default) ---
# 服务端接收伪装的 TLS 连接，解密后转发给 FRP
# Server receives disguised TLS connections, decrypts and forwards to FRP
SHADOW_TLS_ENABLED=false
SHADOW_TLS_LISTEN=0.0.0.0:8443          # 监听端口 / Listen port (use 8443 to avoid Caddy conflict on 443)
SHADOW_TLS_BACKEND=127.0.0.1:7000       # 转发到 frps 的地址 / Forward to frps address
SHADOW_TLS_SNI=www.microsoft.com         # 伪装域名 / Disguise domain (must match client)
#SHADOW_TLS_PASSWORD=your-password       # 两端必须一致 / Must match client side

# --- Hysteria2 (默认关闭) / Hysteria2 (off by default) ---
# 启用后需提供 config/hysteria2-server.yaml
# When enabled, provide config/hysteria2-server.yaml
HYSTERIA2_ENABLED=false

# --- 健康检查 / Health check ---
# 需要 frps.toml 中启用 webServer 才生效
# Requires webServer enabled in frps.toml
FRP_ADMIN_ADDR=127.0.0.1
FRP_ADMIN_PORT=7500
FRP_ADMIN_USER=admin
#FRP_ADMIN_PWD=
#FRP_HEALTH_CHECK_URL=
