<form>
    <field>
        <id>server.enabled</id>
        <label>Enable FRP Server</label>
        <type>checkbox</type>
        <help>Enable or disable the FRP server (frps).</help>
    </field>
    <field>
        <id>server.bindAddr</id>
        <label>Bind Address</label>
        <type>text</type>
        <help>Address to bind on (default: 0.0.0.0).</help>
    </field>
    <field>
        <id>server.bindPort</id>
        <label>Bind Port</label>
        <type>text</type>
        <help>Port to listen on (default: 7000).</help>
    </field>
    <field>
        <id>server.authMethod</id>
        <label>Authentication Method</label>
        <type>dropdown</type>
        <help>Authentication method for client connections.</help>
    </field>
    <field>
        <id>server.authToken</id>
        <label>Authentication Token</label>
        <type>password</type>
        <help>Token for client authentication.</help>
    </field>
    <field>
        <id>server.logLevel</id>
        <label>Log Level</label>
        <type>dropdown</type>
        <help>FRP server logging verbosity.</help>
    </field>
    <field>
        <type>header</type>
        <label>Transport Settings</label>
        <advanced>true</advanced>
    </field>
    <field>
        <id>server.transportProtocol</id>
        <label>Transport Protocol</label>
        <type>dropdown</type>
        <help>Transport protocol. WSS (WebSocket over TLS) makes FRP traffic look like normal HTTPS, harder for GFW to detect. Both client and server must match.</help>
        <advanced>true</advanced>
    </field>
    <field>
        <id>server.transportTcpMux</id>
        <label>TCP Multiplexing</label>
        <type>checkbox</type>
        <help>Enable TCP multiplexing.</help>
        <advanced>true</advanced>
    </field>
    <field>
        <id>server.transportTlsForce</id>
        <label>Force TLS</label>
        <type>checkbox</type>
        <help>Force clients to use TLS connections.</help>
        <advanced>true</advanced>
    </field>
    <field>
        <id>server.maxPoolCount</id>
        <label>Max Pool Count</label>
        <type>text</type>
        <help>Maximum connection pool size per client (default: 5).</help>
        <advanced>true</advanced>
    </field>
    <field>
        <type>header</type>
        <label>Web Dashboard</label>
        <advanced>true</advanced>
    </field>
    <field>
        <id>server.webServerEnabled</id>
        <label>Enable Dashboard</label>
        <type>checkbox</type>
        <help>Enable the FRP web dashboard.</help>
        <advanced>true</advanced>
    </field>
    <field>
        <id>server.webServerAddr</id>
        <label>Dashboard Address</label>
        <type>text</type>
        <help>Dashboard listen address (default: 127.0.0.1).</help>
        <advanced>true</advanced>
    </field>
    <field>
        <id>server.webServerPort</id>
        <label>Dashboard Port</label>
        <type>text</type>
        <help>Dashboard listen port (default: 7500).</help>
        <advanced>true</advanced>
    </field>
    <field>
        <id>server.webServerUser</id>
        <label>Dashboard Username</label>
        <type>text</type>
        <help>Dashboard login username (default: admin).</help>
        <advanced>true</advanced>
    </field>
    <field>
        <id>server.webServerPassword</id>
        <label>Dashboard Password</label>
        <type>password</type>
        <help>Dashboard login password.</help>
        <advanced>true</advanced>
    </field>
    <field>
        <type>header</type>
        <label>Network Tuning</label>
        <advanced>true</advanced>
    </field>
    <field>
        <id>server.bbrEnabled</id>
        <label>Enable BBR</label>
        <type>checkbox</type>
        <help>Enables BBR congestion control. WARNING: This is a system-wide kernel setting that affects ALL TCP connections, not just FRP.</help>
        <advanced>true</advanced>
    </field>
    <field>
        <id>server.mssClampEnabled</id>
        <label>Enable MSS Clamping</label>
        <type>checkbox</type>
        <help>Clamps TCP MSS on WAN for FRP tunnel traffic. Fixes speed issues when cross-border links have low MTU (e.g., PPPoE). Recommended value: 1260 for MTU 1300.</help>
        <advanced>true</advanced>
    </field>
    <field>
        <id>server.mssValue</id>
        <label>MSS Value</label>
        <type>text</type>
        <help>Maximum Segment Size in bytes (default: 1260, range: 536-1460). Use 1260 to match Docker MTU 1300.</help>
        <advanced>true</advanced>
    </field>
    <field>
        <type>header</type>
        <label>Virtual Host</label>
        <advanced>true</advanced>
    </field>
    <field>
        <id>server.vhostHTTPPort</id>
        <label>HTTP VHost Port</label>
        <type>text</type>
        <help>Port for HTTP proxy-type tunnels. When clients use http proxy type with customDomains, FRP server routes traffic based on Host header on this port (0 = disabled).</help>
        <advanced>true</advanced>
    </field>
    <field>
        <id>server.vhostHTTPSPort</id>
        <label>HTTPS VHost Port</label>
        <type>text</type>
        <help>Port for HTTPS proxy-type tunnels. When clients use https proxy type with customDomains, FRP server routes traffic based on SNI on this port (0 = disabled).</help>
        <advanced>true</advanced>
    </field>
</form>
