<model>
    <mount>//OPNsense/frp/server</mount>
    <description>FRP Server Settings</description>
    <version>1.0.0</version>
    <items>
        <enabled type="BooleanField">
            <default>0</default>
            <Required>Y</Required>
        </enabled>
        <bindAddr type="TextField">
            <default>0.0.0.0</default>
        </bindAddr>
        <bindPort type="IntegerField">
            <default>7000</default>
            <Required>Y</Required>
            <MinimumValue>1</MinimumValue>
            <MaximumValue>65535</MaximumValue>
        </bindPort>
        <authMethod type="OptionField">
            <default>token</default>
            <BlankDesc>None</BlankDesc>
            <OptionValues>
                <token>Token</token>
            </OptionValues>
        </authMethod>
        <authToken type="TextField"/>
        <transportTcpMux type="BooleanField">
            <default>1</default>
        </transportTcpMux>
        <transportTlsForce type="BooleanField">
            <default>0</default>
        </transportTlsForce>
        <transportTcpKeepalive type="IntegerField">
            <default>60</default>
            <MinimumValue>-1</MinimumValue>
            <MaximumValue>86400</MaximumValue>
        </transportTcpKeepalive>
        <transportTcpMuxKeepaliveInterval type="IntegerField">
            <default>30</default>
            <MinimumValue>1</MinimumValue>
            <MaximumValue>600</MaximumValue>
        </transportTcpMuxKeepaliveInterval>
        <transportHeartbeatTimeout type="IntegerField">
            <default>-1</default>
            <MinimumValue>-1</MinimumValue>
            <MaximumValue>600</MaximumValue>
        </transportHeartbeatTimeout>
        <maxPoolCount type="IntegerField">
            <default>5</default>
            <MinimumValue>0</MinimumValue>
            <MaximumValue>100</MaximumValue>
        </maxPoolCount>
        <monitorInterval type="OptionField">
            <default>2</default>
            <OptionValues>
                <option1 value="1">1s</option1>
                <option2 value="2">2s</option2>
                <option5 value="5">5s</option5>
                <option10 value="10">10s</option10>
                <option30 value="30">30s</option30>
            </OptionValues>
        </monitorInterval>
        <webServerEnabled type="BooleanField">
            <default>0</default>
        </webServerEnabled>
        <webServerAddr type="TextField">
            <default>127.0.0.1</default>
        </webServerAddr>
        <webServerPort type="IntegerField">
            <default>7500</default>
            <MinimumValue>1</MinimumValue>
            <MaximumValue>65535</MaximumValue>
        </webServerPort>
        <webServerUser type="TextField">
            <default>admin</default>
        </webServerUser>
        <webServerPassword type="TextField"/>
        <vhostHTTPPort type="IntegerField">
            <default>0</default>
            <MinimumValue>0</MinimumValue>
            <MaximumValue>65535</MaximumValue>
        </vhostHTTPPort>
        <vhostHTTPSPort type="IntegerField">
            <default>0</default>
            <MinimumValue>0</MinimumValue>
            <MaximumValue>65535</MaximumValue>
        </vhostHTTPSPort>
        <bbrEnabled type="BooleanField">
            <default>0</default>
        </bbrEnabled>
        <mssClampEnabled type="BooleanField">
            <default>0</default>
        </mssClampEnabled>
        <mssValue type="IntegerField">
            <default>1260</default>
            <MinimumValue>536</MinimumValue>
            <MaximumValue>1460</MaximumValue>
        </mssValue>
        <kcpBindPort type="IntegerField">
            <default>0</default>
            <MinimumValue>0</MinimumValue>
            <MaximumValue>65535</MaximumValue>
        </kcpBindPort>
        <quicBindPort type="IntegerField">
            <default>0</default>
            <MinimumValue>0</MinimumValue>
            <MaximumValue>65535</MaximumValue>
        </quicBindPort>
        <transportQuicKeepalivePeriod type="IntegerField">
            <default>10</default>
            <MinimumValue>1</MinimumValue>
            <MaximumValue>600</MaximumValue>
        </transportQuicKeepalivePeriod>
        <transportQuicMaxIdleTimeout type="IntegerField">
            <default>30</default>
            <MinimumValue>5</MinimumValue>
            <MaximumValue>600</MaximumValue>
        </transportQuicMaxIdleTimeout>
        <transportQuicMaxIncomingStreams type="IntegerField">
            <default>100000</default>
            <MinimumValue>1</MinimumValue>
            <MaximumValue>1000000</MaximumValue>
        </transportQuicMaxIncomingStreams>
        <userConnTimeout type="IntegerField">
            <default>10</default>
            <MinimumValue>1</MinimumValue>
            <MaximumValue>120</MaximumValue>
        </userConnTimeout>
        <maxPortsPerClient type="IntegerField">
            <default>0</default>
            <MinimumValue>0</MinimumValue>
            <MaximumValue>65535</MaximumValue>
        </maxPortsPerClient>
        <udpPacketSize type="IntegerField">
            <default>1500</default>
            <MinimumValue>500</MinimumValue>
            <MaximumValue>9000</MaximumValue>
        </udpPacketSize>
        <logLevel type="OptionField">
            <default>info</default>
            <OptionValues>
                <trace>Trace</trace>
                <debug>Debug</debug>
                <info>Info</info>
                <warn>Warning</warn>
                <error>Error</error>
            </OptionValues>
        </logLevel>
    </items>
</model>
