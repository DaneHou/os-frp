# Shadow-TLS Server Configuration
# Disguises FRP traffic as normal HTTPS to evade GFW DPI

SHADOW_TLS_ENABLED=false
SHADOW_TLS_LISTEN=0.0.0.0:443
SHADOW_TLS_PASSWORD=your-password
SHADOW_TLS_SNI=www.microsoft.com
SHADOW_TLS_BACKEND=127.0.0.1:7000

# Traffic flow:
# internet -> shadow-tls-server:443 -> frps:7000
# External observers see HTTPS traffic to www.microsoft.com
